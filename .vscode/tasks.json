{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "outFile",
            "type": "promptString",
            "description": "Output CSV filename (without .csv extension)",
            "default": "out"
        }
    ],
    "tasks": [
        {
            "label": "Build (debug)",
            "type": "shell",
            "command": "g++ -std=c++20 -g model/*.cpp -o model/main",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Build (run fast)",
            "type": "shell",
            "command": "g++ -std=c++20 -O2 model/*.cpp -o model/main",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Build and Run (debug)",
            "type": "shell",
            "command": "g++ -std=c++20 -g model/*.cpp -o model/main && cd model && ./main ../output/${input:outFile}.csv",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Build and Run (run fast)",
            "type": "shell",
            "command": "g++ -std=c++20 -O2 model/*.cpp -o model/main && cd model && ./main ../output/${input:outFile}.csv",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        }
    ]
}
