{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "g++ -std=c++11 -g model/*.cpp -o model/main",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "g++ -std=c++11 -g model/*.cpp -o model/main && cd model && ./main ../output/out.csv",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        }
    ]
}
